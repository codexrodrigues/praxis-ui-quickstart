{
  "name": "praxis-ui-quickstart",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "praxis:local-libs:sync": "node ./tools/sync-local-praxis-tsconfig.mjs",
    "start": "ng serve --host 127.0.0.1 --port 4301",
    "start:local-praxis": "npm run praxis:local-libs:sync && ng serve --configuration local-praxis --prebundle=false",
    "build": "ng build",
    "build:local-praxis": "npm run praxis:local-libs:sync && ng build --configuration local-praxis",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:smoke": "ng test --watch=false --browsers=ChromeHeadless"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.14",
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/material": "^21.2.12",
    "@angular/platform-browser": "^21.2.14",
    "@angular/platform-browser-dynamic": "^21.2.14",
    "@angular/router": "^21.2.14",
    "@google/generative-ai": "^0.24.1",
    "@praxisui/ai": "8.0.0-beta.85",
    "@praxisui/charts": "8.0.0-beta.85",
    "@praxisui/core": "8.0.0-beta.85",
    "@praxisui/cron-builder": "8.0.0-beta.85",
    "@praxisui/crud": "8.0.0-beta.85",
    "@praxisui/dialog": "8.0.0-beta.85",
    "@praxisui/dynamic-fields": "8.0.0-beta.85",
    "@praxisui/dynamic-form": "8.0.0-beta.85",
    "@praxisui/editorial-forms": "8.0.0-beta.85",
    "@praxisui/expansion": "8.0.0-beta.85",
    "@praxisui/files-upload": "8.0.0-beta.85",
    "@praxisui/list": "8.0.0-beta.85",
    "@praxisui/manual-form": "8.0.0-beta.85",
    "@praxisui/metadata-editor": "8.0.0-beta.85",
    "@praxisui/page-builder": "8.0.0-beta.85",
    "@praxisui/rich-content": "8.0.0-beta.85",
    "@praxisui/settings-panel": "8.0.0-beta.85",
    "@praxisui/stepper": "8.0.0-beta.85",
    "@praxisui/table": "8.0.0-beta.85",
    "@praxisui/table-rule-builder": "8.0.0-beta.85",
    "@praxisui/tabs": "8.0.0-beta.85",
    "@praxisui/visual-builder": "8.0.0-beta.85",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.14",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}

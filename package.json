{
  "name": "praxis-ui-quickstart",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "praxis:local-libs:sync": "node ./tools/sync-local-praxis-tsconfig.mjs",
    "start": "ng serve --host 127.0.0.1 --port 4301",
    "start:local-praxis": "npm run praxis:local-libs:sync && ng serve --configuration local-praxis",
    "build": "ng build",
    "build:local-praxis": "npm run praxis:local-libs:sync && ng build --configuration local-praxis",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:smoke": "ng test --watch=false --browsers=ChromeHeadless"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/cdk": "^20.1.4",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.1.4",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@google/generative-ai": "^0.24.1",
    "@praxisui/ai": "^8.0.0-beta.0",
    "@praxisui/charts": "^8.0.0-beta.0",
    "@praxisui/core": "^8.0.0-beta.0",
    "@praxisui/cron-builder": "^8.0.0-beta.0",
    "@praxisui/crud": "^8.0.0-beta.0",
    "@praxisui/dynamic-fields": "^8.0.0-beta.0",
    "@praxisui/dynamic-form": "^8.0.0-beta.0",
    "@praxisui/editorial-forms": "^8.0.0-beta.0",
    "@praxisui/expansion": "^8.0.0-beta.0",
    "@praxisui/list": "^8.0.0-beta.0",
    "@praxisui/manual-form": "^8.0.0-beta.0",
    "@praxisui/stepper": "^8.0.0-beta.0",
    "@praxisui/table": "^8.0.0-beta.0",
    "@praxisui/tabs": "^8.0.0-beta.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.21",
    "@angular/cli": "^20.3.21",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
